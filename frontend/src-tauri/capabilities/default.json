{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$DESKTOP/**" }
      ]
    },
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "dialog:allow-message",
    "dialog:allow-open",
    "dialog:default"
  ]
}
